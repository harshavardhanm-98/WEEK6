#include <stdio.h>
int main() {
    int a[100], i, n, sum = 0;
    printf("Enter size of the array: ");
    scanf("%d", &n);
    printf("Enter %d elements: ", n);
    for(i = 0; i < n; i++) {
        scanf("%d", &a[i]);
        sum += a[i];
    }

    printf("Sum of all elements = %d", sum);
    return 0;
}

